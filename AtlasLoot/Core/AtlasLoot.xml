	<Frame name="AtlasLootInfo">
		<Size x="128" y="75"/>
		<Frames>
			<Button name="$parentHidePanel" inherits="OptionsButtonTemplate">
				<Size x="140" y="20"/>
				<Anchors>
					<Anchor point="BOTTOMLEFT" x="-5" y="-3"/>
				</Anchors>
				<Scripts>
					<OnShow>
						local AL = LibStub("AceLocale-3.0"):GetLocale("AtlasLoot")
						self:SetFrameLevel(self:GetParent():GetFrameLevel() + 3)
						self:SetText(AL["Toggle AL Panel"])
						self:SetWidth(self:GetTextWidth() + 20)
						AtlasLootInfo_Text2:SetText(AL["Click boss name to view loot."])
					</OnShow>
					<OnClick>
						if AtlasLoot.db.profile.HidePanel then
							AtlasLoot.db.profile.HidePanel = false
							if AtlasFrame and AtlasFrame:IsVisible() then
								AtlasLootPanel:Show()
							end
						else
							AtlasLoot.db.profile.HidePanel = true
							if AtlasFrame and AtlasFrame:IsVisible() then
								AtlasLootPanel:Hide()
							end
						end
						AtlasLootOptionsFrameHidePanel:SetChecked(AtlasLoot.db.profile.HidePanel)
						AtlasLoot_SetupForAtlas()
					</OnClick>
				</Scripts>
			</Button>
		</Frames>
		<Layers>
			<Layer level="OVERLAY">
				<FontString name="$parent_Text1" inherits="GameFontNormalSmall" text="ATLASLOOT_VERSION" justifyH="LEFT">
					<Size x="180" y="10"/>
					<Anchor point="TOPLEFT" x="0" y="25"/>
				</FontString>
				<FontString name="$parent_Text2" inherits="GameFontNormalSmall" justifyH="LEFT">
					<Size x="180" y="10"/>
					<Anchors>
						<Anchor point="TOPLEFT" relativeTo="$parent_Text1" relativePoint="BOTTOMLEFT" x="0" y="-2"/>
					</Anchors>
				</FontString>
			</Layer>
		</Layers>
	</Frame>

