	<Button name="AtlasLootContainerItemTemplate" virtual="true">
		<Size x="40" y="40"/>
		<Layers>
			<Layer level="BACKGROUND">
				<Texture name="$parentIcon" parentKey="Icon">
					<Size x="32" y="32"/>
					<Anchors>
						<Anchor point="TOPLEFT" x="4" y="-4"/>
					</Anchors>
				</Texture>
			</Layer>
			<Layer level="OVERLAY">
				<Texture name="$parentIconBorder" parentKey="IconBorder" file="Interface\AddOns\AtlasLoot\Images\border">
					<Size x="41" y="41"/>
