	<GameTooltip name="AtlasLootTooltip" inherits="GameTooltipTemplate" parent="UIParent" hidden="true">
		<Scripts>
			<OnLoad function="AtlasLootTooltip_OnLoad"/>
			<OnTooltipSetItem>
				if IsModifiedClick("COMPAREITEMS") or (GetCVarBool("alwaysCompareItems") and not self:IsEquippedItem()) then
					GameTooltip_ShowCompareItem(self, true)
				end
			</OnTooltipSetItem>
			<OnHide function="GameTooltip_OnHide"/>
			<OnUpdate function="GameTooltip_OnUpdate"/>
		</Scripts>
	</GameTooltip>

