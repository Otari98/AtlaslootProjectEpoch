<Ui xmlns="http://www.blizzard.com/wow/ui/">

	<Script file="DewDropDown.lua"/>
	<Script file="AtlaslootDefaultFrame.lua"/>

	<Button name="AtlasLootDefaultFrameButtonTemplate" inherits="UIPanelButtonTemplate" virtual="true">
		<Size x="105" y="20"/>
	</Button>

	<Frame name="AtlasLootDefaultFrame" toplevel="true" movable="true" enableMouse="true" hidden="true" parent="UIParent" enableKeyboard="true">
		<Size x="600" y="690"/>
		<Anchors>
			<Anchor point="CENTER"/>
		</Anchors>
		<Backdrop bgFile="Interface\DialogFrame\UI-DialogBox-Background" edgeFile="Interface\DialogFrame\UI-DialogBox-Border" tile="true">
			<BackgroundInsets left="11" right="12" top="12" bottom="11"/>
			<TileSize val="32"/>
			<EdgeSize val="32"/>
		</Backdrop>
		<Frames>
			<Button name="$parent_CloseButton" inherits="UIPanelCloseButton">
				<Anchors>
					<Anchor point="TOPRIGHT" relativeTo="AtlasLootDefaultFrame" relativePoint="TOPRIGHT" x="-10" y="-10"/>
				</Anchors>
				<Scripts>
					<OnClick>
						AtlasLootDefaultFrame:Hide()
					</OnClick>
					<OnShow>
						self:SetFrameLevel(self:GetParent():GetFrameLevel() +1)
					</OnShow>
				</Scripts>
			</Button>
			<Button name="$parent_LoadModules" inherits="AtlasLootDefaultFrameButtonTemplate">
				<Anchors>
					<Anchor point="TOPRIGHT" x="-38" y="-15"/>
				</Anchors>
				<Scripts>
					<OnClick>
						AtlasLoot_LoadAllModules()
					</OnClick>
					<OnShow>
						local AL = LibStub("AceLocale-3.0"):GetLocale("AtlasLoot")
						self:SetText(AL["Load Modules"])
						self:SetFrameLevel(self:GetParent():GetFrameLevel() +1)
					</OnShow>
				</Scripts>
			</Button>
			<Button name="$parent_Options" inherits="AtlasLootDefaultFrameButtonTemplate">
				<Anchors>
					<Anchor point="TOPLEFT" x="15" y="-15"/>
				</Anchors>
				<Scripts>
					<OnClick>
						AtlasLootOptions_Toggle()
					</OnClick>
					<OnShow>
						local AL = LibStub("AceLocale-3.0"):GetLocale("AtlasLoot")
						self:SetText(AL["Options"])
						self:SetFrameLevel(self:GetParent():GetFrameLevel() +1)
					</OnShow>
				</Scripts>
			</Button>
			<Button name="$parent_Menu" inherits="OptionsButtonTemplate">
				<Size x="130" y="20"/>
				<Anchors>
					<Anchor point="TOP" x="-130" y="-40"/>
				</Anchors>
				<Scripts>
					<OnClick>
						if AtlasLoot_Dewdrop:IsOpen() then
							AtlasLoot_Dewdrop:Close()
						else
							AtlasLoot_Dewdrop:Open(self)
						end
					</OnClick>
					<OnShow>
						local AL = LibStub("AceLocale-3.0"):GetLocale("AtlasLoot")
						self:SetText(AL["Select Loot Table"])
						self:SetFrameLevel(self:GetParent():GetFrameLevel() +1)
					</OnShow>
				</Scripts>
			</Button>
			<Button name="$parent_SubMenu" inherits="OptionsButtonTemplate">
				<Size x="130" y="20"/>
				<Anchors>
					<Anchor point="TOP" x="130" y="-40"/>
				</Anchors>
				<Scripts>
					<OnClick>
						if AtlasLoot_DewdropSubMenu:IsOpen() then
							AtlasLoot_DewdropSubMenu:Close()
						else
							AtlasLoot_DewdropSubMenu:Open(self)
						end
					</OnClick>
					<OnShow>
						local AL = LibStub("AceLocale-3.0"):GetLocale("AtlasLoot")
						self:SetText(AL["Select Sub-Table"])
						self:SetFrameLevel(self:GetParent():GetFrameLevel() +1)
					</OnShow>
				</Scripts>
			</Button>
			<Frame name="$parent_LootBackground" enableMouse="false">
				<Size x="515" y="515"/>
				<Anchors>
					<Anchor point="BOTTOM" x="0" y="90"/>
				</Anchors>
			</Frame>
			<Button name="$parent_Preset1" inherits="AtlasLootQuickLookButtonTemplate" id="1">
				<Anchors>
					<Anchor point="BOTTOMLEFT" x="62" y="63"/>
				</Anchors>
			</Button>
			<Button name="$parent_Preset2" inherits="AtlasLootQuickLookButtonTemplate" id="2">
				<Anchors>
					<Anchor point="LEFT" relativeTo="$parent_Preset1" relativePoint="RIGHT" x="0" y="0"/>
				</Anchors>
			</Button>
			<Button name="$parent_Preset3" inherits="AtlasLootQuickLookButtonTemplate" id="3">
				<Anchors>
					<Anchor point="LEFT" relativeTo="$parent_Preset2" relativePoint="RIGHT" x="0" y="0"/>
				</Anchors>
			</Button>
			<Button name="$parent_Preset4" inherits="AtlasLootQuickLookButtonTemplate" id="4">
				<Anchors>
					<Anchor point="LEFT" relativeTo="$parent_Preset3" relativePoint="RIGHT" x="0" y="0"/>
				</Anchors>
			</Button>
			<EditBox name="AtlasLootDefaultFrameSearchBox" inherits="InputBoxTemplate" letters="100">
				<Size x="180" y="32" />
				<Anchors>
					<Anchor point="BOTTOM" x="-70" y="30"/>
				</Anchors>
				<Scripts>
					<OnLoad>
						self:SetAutoFocus(false)
						self:SetTextInsets(0, 8, 0, 0)
					</OnLoad>
					<OnTextChanged>
						AtlasLoot:RefreshSearchSuggestions(self)
					</OnTextChanged>
					<OnMouseDown>
						AtlasLoot:ShowSearchSuggestions(self)
					</OnMouseDown>
					<OnEditFocusGained>
						AtlasLoot:ShowSearchSuggestions(self)
					</OnEditFocusGained>
					<OnEditFocusLost>
						AtlasLoot:HideSearchSuggestions(self)
					</OnEditFocusLost>
					<OnTabPressed>
						AtlasLoot:AutoComplete(self)
					</OnTabPressed>
					<OnEnterPressed>
						AtlasLoot:Search(self:GetText())
						self:ClearFocus()
						AtlasLoot:HideSearchSuggestions(self)
					</OnEnterPressed>
				</Scripts>
				<FontString name="AtlasLootDefaultFrameSearchString" inherits="GameFontNormal"></FontString>
			</EditBox>
			<Button name="AtlasLootDefaultFrameSearchButton" inherits="UIPanelButtonTemplate2" parent="AtlasLootDefaultFrameSearchBox">
				<Size x="69" y="32"/>
				<Anchors>
					<Anchor point="LEFT" relativePoint="RIGHT" x="0" y="0"/>
				</Anchors>
				<Scripts>
					<OnShow>
						local AL = LibStub("AceLocale-3.0"):GetLocale("AtlasLoot")
						self:SetText(AL["Search"])
						self:SetFrameLevel(self:GetParent():GetFrameLevel() +1)
					</OnShow>
					<OnClick>
						AtlasLoot:Search(AtlasLootDefaultFrameSearchBox:GetText())
						AtlasLootDefaultFrameSearchBox:ClearFocus()
						AtlasLoot:HideSearchSuggestions(AtlasLootDefaultFrameSearchBox)
					</OnClick>
				</Scripts>
			</Button>
			<Button name="AtlasLootDefaultFrameSearchOptionsButton" parent="AtlasLootDefaultFrameSearchButton">
				<Size x="28" y="28" />
				<Anchors>
					<Anchor point="LEFT" relativeTo="AtlasLootDefaultFrameSearchButton" relativePoint="RIGHT" x="-6" y="0"/>
				</Anchors>
				<NormalTexture file="Interface\Buttons\UI-SpellbookIcon-NextPage-Up"/>
				<PushedTexture file="Interface\Buttons\UI-SpellbookIcon-NextPage-Down"/>
				<DisabledTexture file="Interface\Buttons\UI-SpellbookIcon-NextPage-Disabled"/>
				<HighlightTexture file="Interface\Buttons\UI-Common-MouseHilight" alphaMode="ADD"/>
				<Scripts>
					<OnShow>
						self:SetFrameLevel(self:GetParent():GetFrameLevel() +1)
					</OnShow>
					<OnClick>
						AtlasLoot:ShowSearchOptions(self)
					</OnClick>
				</Scripts>
			</Button>
			<Button name="AtlasLootDefaultFrameSearchClearButton" inherits="UIPanelButtonTemplate2" parent="AtlasLootDefaultFrameSearchBox">
				<Size x="58" y="32"/>
				<Anchors>
					<Anchor point="LEFT" relativeTo="AtlasLootDefaultFrameSearchOptionsButton" relativePoint="RIGHT" x="-2" y="0"/>
				</Anchors>
				<Scripts>
					<OnShow>
						local AL = LibStub("AceLocale-3.0"):GetLocale("AtlasLoot")
						self:SetText(AL["Clear"])
						self:SetFrameLevel(self:GetParent():GetFrameLevel() +1)
					</OnShow>
					<OnClick>
						AtlasLootDefaultFrameSearchBox:SetText("")
						AtlasLootDefaultFrameSearchBox:ClearFocus()
					</OnClick>
				</Scripts>
			</Button>
			<Button name="AtlasLootDefaultFrameLastResultButton" inherits="UIPanelButtonTemplate2" parent="AtlasLootDefaultFrameSearchBox">
				<Size x="100" y="32"/>
				<Anchors>
					<Anchor point="LEFT" relativeTo="AtlasLootDefaultFrameSearchClearButton" relativePoint="RIGHT" x="0" y="0"/>
				</Anchors>
				<Scripts>
					<OnShow>
						local AL = LibStub("AceLocale-3.0"):GetLocale("AtlasLoot")
						self:SetText(AL["Last Result"])
						self:SetFrameLevel(self:GetParent():GetFrameLevel() +1)
					</OnShow>
					<OnClick>
						AtlasLoot:ShowSearchResult()
					</OnClick>
				</Scripts>
			</Button>
			<Button name="AtlasLootDefaultFrameWishListButton" inherits="UIPanelButtonTemplate2" parent="AtlasLootDefaultFrame">
				<Size x="100" y="32"/>
				<Anchors>
					<Anchor point="RIGHT" relativeTo="AtlasLootDefaultFrameSearchBox" relativePoint="LEFT" x="-7" y="0"/>
				</Anchors>
				<Scripts>
					<OnClick>
						AtlasLoot_ShowWishListDropDown("", "", "", "", "", self, true)
					</OnClick>
					<OnShow>
						local AL = LibStub("AceLocale-3.0"):GetLocale("AtlasLoot")
						self:SetText(AL["Wishlist"])
						self:SetFrameLevel(self:GetParent():GetFrameLevel() +1)
					</OnShow>
				</Scripts>
			</Button>
		</Frames>
		<Layers>
			<Layer level="ARTWORK">
				<Texture name="$parentHeader" file="Interface\DialogFrame\UI-DialogBox-Header">
					<Size x="425" y="64"/>
					<Anchors>
						<Anchor point="TOP" x="0" y="12"/>
					</Anchors>
				</Texture>
				<FontString inherits="GameFontNormal" text="ATLASLOOT_VERSION">
					<Anchors>
						<Anchor point="TOP" x="0" y="-1"/>
					</Anchors>
				</FontString>
				<FontString name="$parent_Notice" inherits="GameFontNormal">
					<Anchors>
						<Anchor point="BOTTOM" x="0" y="17"/>
					</Anchors>
				</FontString>
			</Layer>
			<Layer level="OVERLAY">
				<FontString name="$parent_SelectedCategory" inherits="GameFontNormal" text="">
					<Anchors>
						<Anchor point="TOP" x="0" y="-50"/>
					</Anchors>
				</FontString>
				<FontString name="$parent_SelectedTable" inherits="GameFontNormal" text="Cannot read files">
					<Anchors>
						<Anchor point="TOP" x="0" y="-50"/>
					</Anchors>
				</FontString>
			</Layer>
		</Layers>
		<Scripts>
			<OnLoad>
				self:RegisterForDrag("LeftButton")
				self:SetMovable(1)
				self:SetBackdropColor(0.75, 0, 0.75)
				local AL = LibStub("AceLocale-3.0"):GetLocale("AtlasLoot")
				AtlasLootDefaultFrame_Notice:SetText(AL["This is a loot browser only.  To view maps as well, install either Atlas or Alphamap."])
			</OnLoad>
			<OnShow>
				AtlasLootDefaultFrame_OnShow()
			</OnShow>
			<OnHide>
				AtlasLootDefaultFrame_OnHide()
			</OnHide>
			<OnDragStart>
				self:StartMoving()
			</OnDragStart>
			<OnDragStop>
				self:StopMovingOrSizing()
			</OnDragStop>
			<OnMouseUp>
				CloseDropDownMenus()
			</OnMouseUp>
		</Scripts>
	</Frame>

</Ui>